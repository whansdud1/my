# ============================================================================
# UniTeam 공통 환경 변수 (개발용 예시)
# 운영에서는 비밀저장소(Vault, AWS Secrets Manager 등)로 분리
# ============================================================================

# --- 공통 ---
NODE_ENV=development
PUBLIC_BASE_URL=https://p18.sumzip.com
APP_BASE_URL=http://localhost:9518
API_BASE_URL=http://localhost:9538

# --- Backend (port=9538 고정) ---
PORT=9538
LOG_LEVEL=info

# DB (개발: docker-compose의 mariadb 서비스)
DB_HOST=mariadb
DB_PORT=3306
DB_USER=uniteam
DB_PASSWORD=change_me_in_secret_store
DB_NAME=uniteam

# JWT (운영에서는 32+ 바이트 무작위 값으로 교체)
JWT_ACCESS_SECRET=replace_with_32_byte_random_in_prod
JWT_REFRESH_SECRET=replace_with_another_32_byte_random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=14d

# CORS (개발 환경에서만 명시; 운영에서는 same-origin이라 불필요)
CORS_ORIGINS=http://localhost:9518,https://p18.sumzip.com

# Email (개발: MailHog / 운영: SES·SendGrid 어댑터로 분기)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@p18.sumzip.com

# Notification (002-notification-system)
NOTIF_WORKER_INTERVAL_MS=10000   # outbox 폴링 주기
NOTIF_ARCHIVE_DAYS=90            # 알림 보관 기간(경과 시 ARCHIVED)
NOTIF_PUSH_ENABLED=false         # WA-01: 1차 푸시 비활성

# OAuth — provider별 키 (운영에서만 채움)
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=https://p18.sumzip.com/api/v1/integrations

# PG (US9 — 1차 미사용, 토스/아임포트 어댑터 활성화 시 입력)
PG_PROVIDER=toss
PG_CLIENT_KEY=
PG_SECRET_KEY=
PG_WEBHOOK_SECRET=

# --- Frontend (port=9518 고정) ---
VITE_API_BASE_URL=/api/v1
VITE_APP_NAME=UniTeam
