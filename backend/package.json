{
  "name": "uniteam-backend",
  "version": "0.1.0",
  "private": true,
  "description": "UniTeam — 대학생 팀 매칭 플랫폼 백엔드 (Express + TypeScript + MariaDB)",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "tsx node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "tsx node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:rollback",
    "migrate:list": "tsx node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:list",
    "seed": "tsx node_modules/knex/bin/cli.js --knexfile knexfile.ts seed:run",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,js}\"",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "cookie-parser": "^1.4.6",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.4.0",
    "mysql2": "^3.11.0",
    "knex": "^3.1.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "zod": "^3.23.8",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "nanoid": "^5.0.7",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.16.5",
    "@types/node": "^20.14.10",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/cookie-parser": "^1.4.7",
    "@types/compression": "^1.7.5",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.12",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "prettier": "^3.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.3",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}
