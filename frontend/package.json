{
  "name": "uniteam-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "UniTeam — 대학생 팀 매칭 플랫폼 프론트엔드 (Vue 3 + Vite + Pinia)",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,vue}\"",
    "format": "prettier --write \"src/**/*.{ts,vue,css,scss,json,md}\"",
    "test": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "socket.io-client": "^4.8.3",
    "vue": "^3.4.31",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.27.0",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "vitest": "^2.0.4",
    "vue-tsc": "^2.0.26"
  }
}
